#!/usr/bin/env python3
"""
Car coupling X-coordinate detector.

Usage:
    ./find_couplings image1.jpg image2.jpg ...

Outputs one x-coordinate per line (integer pixel x of coupling center).
If no coupling is detected in an image, outputs -1.
"""

import sys
import os
from pathlib import Path

# Default model path - can be overridden with env var MODEL_PATH
DEFAULT_MODEL = str(
    Path(__file__).parent / "runs/train/coupling_yolov8n/weights/best.pt"
)
MODEL_PATH = os.environ.get("MODEL_PATH", DEFAULT_MODEL)


def load_model():
    try:
        from ultralytics import YOLO
    except ImportError:
        print(
            "ultralytics not installed. Run: pip install ultralytics", file=sys.stderr
        )
        sys.exit(1)

    if not Path(MODEL_PATH).exists():
        print(f"Model not found at: {MODEL_PATH}", file=sys.stderr)
        print("Run train.py first, or set MODEL_PATH env variable.", file=sys.stderr)
        sys.exit(1)

    return YOLO(MODEL_PATH)


def get_x_coordinate(model, image_path: str) -> int:
    """Run inference and return x center of the best detected coupling."""
    results = model(image_path, verbose=False, conf=0.1)

    if not results or len(results) == 0:
        return -1

    result = results[0]
    boxes = result.boxes

    if boxes is None or len(boxes) == 0:
        return -1

    # Pick the box with highest confidence
    confidences = boxes.conf.cpu().numpy()
    best_idx = confidences.argmax()

    # xyxy format: [x1, y1, x2, y2]
    xyxy = boxes.xyxy[best_idx].cpu().numpy()
    x_center = int((xyxy[0] + xyxy[2]) / 2)

    return x_center


def main():
    if len(sys.argv) < 2:
        print("Usage: ./find_couplings image1.jpg image2.jpg ...", file=sys.stderr)
        sys.exit(1)

    image_paths = sys.argv[1:]
    model = load_model()

    for img_path in image_paths:
        if not Path(img_path).exists():
            print(f"WARNING: {img_path} not found", file=sys.stderr)
            print(-1)
            continue

        x = get_x_coordinate(model, img_path)
        print(x)


if __name__ == "__main__":
    main()
